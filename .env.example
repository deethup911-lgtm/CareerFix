# CareerFix — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit your real .env file to version control.

# ── Job Search APIs ────────────────────────────────────────────────────────
# RapidAPI key — used for JSearch (internship/job search) and GeoDB (location autocomplete)
# Get yours at: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna — job listings API (app ID and key)
# Get yours at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# ── AI / LLM ──────────────────────────────────────────────────────────────
# Google Gemini API key — used for resume analysis and content generation
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
